		{
			"name": "3. Diagnostics & Scheduler",
			"item": [
				{
					"name": "Get Email Logs",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/debug/email/logs?page=1&limit=20&allTenants=true",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"debug",
								"email",
								"logs"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "20"
								},
								{
									"key": "status",
									"value": "sent",
									"disabled": true
								},
								{
									"key": "allTenants",
									"value": "true",
									"description": "Set to true to view logs across all organizations. Otherwise returns only current user's organization."
								}
							]
						},
						"description": "Fetch historical log records of sent, queued, or failed emails."
					},
					"response": []
				},
				{
					"name": "Get Email Stats & Queue status",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/debug/email/stats?allTenants=true",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"debug",
								"email",
								"stats"
							],
							"query": [
								{
									"key": "allTenants",
									"value": "true",
									"description": "Set to true to see overall system statistics. If false, shows stats for the active tenant only."
								}
							]
						},
						"description": "Retrieves general email delivery stats from Mongoose logs and fetches direct queue job counts (active, completed, waiting, failed, delayed) from BullMQ."
					},
					"response": []
				},
				{
					"name": "Trigger Daily Expiry Job Manually",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
