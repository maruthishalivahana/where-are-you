{
	"info": {
		"_postman_id": "2e06180a-9d9f-4b0e-b7d1-58f7e2d93e15",
		"name": "NavixGo Email System Testing",
		"description": "Endpoints to test and verify the NavixGo Email Communication System (templates, delivery logs, BullMQ queue status, and daily schedulers).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Admin Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const responseJson = pm.response.json();",
									"if (responseJson && responseJson.accessToken) {",
									"    pm.collectionVariables.set(\"token\", responseJson.accessToken);",
									"    console.log(\"Saved accessToken to collection variable 'token'\");",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@navixgo.in\",\n    \"password\": \"AdminPassword123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/admin/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"admin",
								"login"
							]
						},
						"description": "Log in as an Admin to obtain the accessToken. The test script will automatically save the token for subsequent requests."
					},
					"response": []
				}
			]
		},
