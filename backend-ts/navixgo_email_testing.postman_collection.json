						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/debug/email/trigger-scheduler",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"debug",
								"email",
								"trigger-scheduler"
							]
						},
						"description": "Manually triggers the daily repeatable BullMQ job that queries expiring or expired trial/paid subscriptions and dispatches reminder notifications."
					},
					"response": []
				}
			]
		}
